# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# gh-cli (authentication, do not commit)
gh
gh-cli/
.ssh/
id_ed25519
id_ed25519.pub
ssh_key.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Uploaded images - uncomment to ignore
# /public/uploads/*
